{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://localweb.dev/schemas/learn.lesson.schema.json",
  "title": "LocalWeb Learn Lesson",
  "type": "object",
  "additionalProperties": true,
  "required": ["title"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "subtitle": {
      "type": "string"
    },
    "stage": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "objectives": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "concepts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["term", "definition"],
        "additionalProperties": true,
        "properties": {
          "term": {
            "type": "string"
          },
          "definition": {
            "type": "string"
          },
          "note": {
            "type": "string"
          }
        }
      }
    },
    "structure": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "label"],
            "additionalProperties": true,
            "properties": {
              "id": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "kind": {
                "type": "string",
                "enum": ["prerequisite", "current", "next", "support", "warning"]
              },
              "detail": {
                "type": "string"
              }
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to"],
            "additionalProperties": true,
            "properties": {
              "from": {
                "type": "string"
              },
              "to": {
                "type": "string"
              },
              "label": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "body"],
        "additionalProperties": true,
        "properties": {
          "title": {
            "type": "string"
          },
          "body": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["example", "nonexample", "counterexample", "worked"]
          }
        }
      }
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "prompt"],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_-]+$"
          },
          "type": {
            "type": "string",
            "enum": ["short", "explain", "choice"]
          },
          "prompt": {
            "type": "string"
          },
          "hint": {
            "type": "string"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "label"],
              "additionalProperties": true,
              "properties": {
                "id": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "next": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label"],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  }
}

